// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Single user for MVP
model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  createdAt DateTime @default(now())
  
  scenarios Scenario[]
}

// Core scenario entity
model Scenario {
  id        Int     @id @default(autoincrement())
  userId    Int
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  inputs    ScenarioInputs?
  outputs   SimulationOutputs?
  versions  ScenarioVersion[]
  
  @@index([userId])
}

// Scenario input parameters
model ScenarioInputs {
  id                  Int     @id @default(autoincrement())
  scenarioId          Int     @unique
  
  // Demand parameters
  averageDemand       Float   @default(5000)
  demandVariability   Float   @default(20) // 0-100 %
  demandTrend        String   @default("Stable") // "Stable", "Increasing", "Seasonal"
  
  // Inventory parameters
  startingInventory   Float   @default(2000)
  reorderPoint        Float   @default(500)
  orderQuantity       Float   @default(1000)
  
  // Supply parameters
  supplierLeadTime    Float   @default(14) // days
  delayRisk           Float   @default(10) // 0-100 %
  
  // Cost parameters
  unitCost            Float   @default(50)
  holdingCost         Float   @default(5) // per unit per period
  stockoutPenalty     Float   @default(100) // per unit of unmet demand
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
}

// Simulation output results
model SimulationOutputs {
  id                  Int     @id @default(autoincrement())
  scenarioId          Int     @unique
  
  profit              Float   @default(0)
  totalStockouts      Float   @default(0)
  overstockRisk       Float   @default(0) // percentage
  holdingCostTotal    Float   @default(0)
  stockoutCostTotal   Float   @default(0)
  orderingCostTotal   Float   @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
}

// Version snapshots
model ScenarioVersion {
  id            Int     @id @default(autoincrement())
  scenarioId    Int
  versionNumber Int
  
  // Snapshot of inputs and outputs as JSON
  snapshotInputs   Json
  snapshotOutputs  Json
  
  createdAt DateTime @default(now())
  
  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  
  @@unique([scenarioId, versionNumber])
  @@index([scenarioId])
}
